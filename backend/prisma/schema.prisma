// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============= AUTENTICAÇÃO E USUÁRIOS =============

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      UserRole @default(OPERATOR)
  active    Boolean  @default(true)
  
  // Relacionamentos
  sales     Sale[]
  pdvSessions PdvSession[]
  auditLogs AuditLog[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([email])
  @@index([role])
  @@index([active])
}

enum UserRole {
  ADMIN
  MANAGER
  OPERATOR
}

// ============= AUDITORIA E LOGS =============

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  module    String
  entityId  String?
  oldData   Json?
  newData   Json?
  
  user      User     @relation(fields: [userId], references: [id])
  
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([module])
  @@index([createdAt])
}

// ============= FORNECEDORES =============

model Supplier {
  id        String   @id @default(cuid())
  name      String
  cnpj      String   @unique
  email     String?
  phone     String?
  address   String?
  city      String?
  state     String?
  zipCode   String?
  contact   String?
  
  // Relacionamentos
  products  Product[]
  nfeItems  NfeItem[]
  payables  Payable[]
  
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cnpj])
  @@index([name])
  @@index([active])
}

// ============= PRODUTOS E CATEGORIAS =============

model ProductCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  description String?
  active    Boolean  @default(true)
  
  products  Product[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([active])
}

model ProductBrand {
  id        String   @id @default(cuid())
  name      String   @unique
  active    Boolean  @default(true)
  
  products  Product[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([active])
}

model Product {
  id              String   @id @default(cuid())
  internalCode    String   @unique
  barcode         String   @unique
  name            String
  description     String?
  
  // Relacionamentos
  categoryId      String
  category        ProductCategory @relation(fields: [categoryId], references: [id])
  
  brandId         String?
  brand           ProductBrand? @relation(fields: [brandId], references: [id])
  
  supplierId      String
  supplier        Supplier @relation(fields: [supplierId], references: [id])
  
  // Preços
  costPrice       Decimal  @db.Numeric(10, 2)
  salePrice       Decimal  @db.Numeric(10, 2)
  profitMargin    Decimal  @db.Numeric(5, 2)
  
  // Estoque
  currentStock    Int      @default(0)
  minimumStock    Int      @default(10)
  criticalStock   Int      @default(5)
  
  // Lotes
  batches         ProductBatch[]
  
  // Histórico
  priceHistory    ProductPriceHistory[]
  stockMovements  StockMovement[]
  saleItems       SaleItem[]
  nfeItems        NfeItem[]
  
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  @@index([barcode])
  @@index([internalCode])
  @@index([name])
  @@index([categoryId])
  @@index([supplierId])
  @@index([active])
}

model ProductBatch {
  id              String   @id @default(cuid())
  productId       String
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  batchNumber     String
  expiryDate      DateTime
  quantity        Int
  costPrice       Decimal  @db.Numeric(10, 2)
  
  // Histórico
  stockMovements  StockMovement[]
  saleItems       SaleItem[]
  
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([productId, batchNumber])
  @@index([productId])
  @@index([expiryDate])
}

model ProductPriceHistory {
  id              String   @id @default(cuid())
  productId       String
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  oldCostPrice    Decimal  @db.Numeric(10, 2)
  newCostPrice    Decimal  @db.Numeric(10, 2)
  oldSalePrice    Decimal  @db.Numeric(10, 2)
  newSalePrice    Decimal  @db.Numeric(10, 2)
  
  changedAt       DateTime @default(now())

  @@index([productId])
  @@index([changedAt])
}

// ============= ESTOQUE E MOVIMENTAÇÕES =============

model StockMovement {
  id              String   @id @default(cuid())
  productId       String
  product         Product  @relation(fields: [productId], references: [id])
  
  batchId         String?
  batch           ProductBatch? @relation(fields: [batchId], references: [id])
  
  type            StockMovementType
  quantity        Int
  reason          String?
  
  // Origem da movimentação
  saleId          String?
  sale            Sale? @relation(fields: [saleId], references: [id])
  
  nfeId           String?
  nfe             Nfe? @relation(fields: [nfeId], references: [id])
  
  createdAt       DateTime @default(now())

  @@index([productId])
  @@index([batchId])
  @@index([type])
  @@index([saleId])
  @@index([nfeId])
  @@index([createdAt])
}

enum StockMovementType {
  ENTRY
  EXIT
  ADJUSTMENT
  LOSS
  RETURN_SALE
  RETURN_PURCHASE
}

// ============= NOTAS FISCAIS E XML =============

model Nfe {
  id              String   @id @default(cuid())
  
  // Informações da NF
  nfeNumber       String   @unique
  seriesNumber    String
  issueDate       DateTime
  
  // Fornecedor
  supplierId      String
  supplier        Supplier @relation(fields: [supplierId], references: [id])
  
  // Valores
  totalValue      Decimal  @db.Numeric(12, 2)
  subtotalValue   Decimal  @db.Numeric(12, 2)
  icmsValue       Decimal  @db.Numeric(12, 2)
  
  // XML
  xmlPath         String
  xmlContent      String   @db.Text
  
  // Status
  status          NfeStatus @default(PENDING)
  importedAt      DateTime @default(now())
  
  // Itens
  items           NfeItem[]
  
  // Financeiro
  payables        Payable[]
  
  // Estoque
  stockMovements  StockMovement[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([nfeNumber])
  @@index([supplierId])
  @@index([status])
  @@index([issueDate])
}

enum NfeStatus {
  PENDING
  PROCESSING
  CONFIRMED
  ERROR
  PARTIALLY_IMPORTED
}

model NfeItem {
  id              String   @id @default(cuid())
  nfeId           String
  nfe             Nfe      @relation(fields: [nfeId], references: [id], onDelete: Cascade)
  
  productId       String
  product         Product  @relation(fields: [productId], references: [id])
  
  supplierId      String
  supplier        Supplier @relation(fields: [supplierId], references: [id])
  
  barcode         String
  batchNumber     String?
  expiryDate      DateTime?
  
  quantity        Int
  costPrice       Decimal  @db.Numeric(10, 2)
  totalValue      Decimal  @db.Numeric(12, 2)
  
  createdAt       DateTime @default(now())

  @@index([nfeId])
  @@index([productId])
  @@index([supplierId])
}

// ============= CONTAS A PAGAR =============

model Payable {
  id              String   @id @default(cuid())
  
  // Informações
  description     String
  supplierId      String
  supplier        Supplier @relation(fields: [supplierId], references: [id])
  
  // Valores
  totalValue      Decimal  @db.Numeric(12, 2)
  paidValue       Decimal  @db.Numeric(12, 2) @default(0)
  remainingValue  Decimal  @db.Numeric(12, 2)
  
  // Datas
  dueDate         DateTime
  paymentDate     DateTime?
  
  // Boleto
  boletoNumber    String?
  boletoLineCode  String?
  
  // Status
  status          PayableStatus @default(PENDING)
  
  // NFe relacionada
  nfeId           String?
  nfe             Nfe? @relation(fields: [nfeId], references: [id])
  
  // Parcelamento
  installmentNumber Int?
  totalInstallments Int?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([supplierId])
  @@index([status])
  @@index([dueDate])
  @@index([paymentDate])
  @@index([nfeId])
}

enum PayableStatus {
  PENDING
  PARTIALLY_PAID
  PAID
  CANCELLED
  OVERDUE
}

// ============= CONTAS A RECEBER =============

model Receivable {
  id              String   @id @default(cuid())
  
  // Informações
  description     String
  customerName    String
  
  // Valores
  totalValue      Decimal  @db.Numeric(12, 2)
  paidValue       Decimal  @db.Numeric(12, 2) @default(0)
  remainingValue  Decimal  @db.Numeric(12, 2)
  
  // Datas
  dueDate         DateTime
  paymentDate     DateTime?
  
  // Status
  status          ReceivableStatus @default(PENDING)
  
  // Venda relacionada
  saleId          String?
  sale            Sale? @relation(fields: [saleId], references: [id])
  
  // Parcelamento
  installmentNumber Int?
  totalInstallments Int?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([dueDate])
  @@index([paymentDate])
  @@index([saleId])
}

enum ReceivableStatus {
  PENDING
  PARTIALLY_PAID
  PAID
  CANCELLED
  OVERDUE
}

// ============= VENDAS =============

model Sale {
  id              String   @id @default(cuid())
  
  // Informações
  saleNumber      String   @unique
  
  // Usuário que realizou a venda
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  
  // Tipo de venda
  type            SaleType
  
  // Valores
  subtotalValue   Decimal  @db.Numeric(12, 2)
  discountValue   Decimal  @db.Numeric(12, 2) @default(0)
  totalValue      Decimal  @db.Numeric(12, 2)
  
  // Cliente
  customerName    String?
  customerCpf     String?
  customerEmail   String?
  
  // Status
  status          SaleStatus @default(COMPLETED)
  
  // Itens
  items           SaleItem[]
  
  // Pagamentos
  payments        SalePayment[]
  
  // Financeiro
  receivables     Receivable[]
  
  // Estoque
  stockMovements  StockMovement[]
  
  // PDV Session
  pdvSessionId    String?
  pdvSession      PdvSession? @relation(fields: [pdvSessionId], references: [id])
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  cancelledAt     DateTime?

  @@index([saleNumber])
  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@index([pdvSessionId])
}

enum SaleType {
  FISCAL
  NON_FISCAL
  COUNTER
  BUDGET
}

enum SaleStatus {
  COMPLETED
  CANCELLED
  PENDING
}

model SaleItem {
  id              String   @id @default(cuid())
  saleId          String
  sale            Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  
  productId       String
  product         Product  @relation(fields: [productId], references: [id])
  
  batchId         String?
  batch           ProductBatch? @relation(fields: [batchId], references: [id])
  
  quantity        Int
  unitPrice       Decimal  @db.Numeric(10, 2)
  discountValue   Decimal  @db.Numeric(10, 2) @default(0)
  totalValue      Decimal  @db.Numeric(12, 2)
  
  createdAt       DateTime @default(now())

  @@index([saleId])
  @@index([productId])
  @@index([batchId])
}

model SalePayment {
  id              String   @id @default(cuid())
  saleId          String
  sale            Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  
  method          PaymentMethod
  value           Decimal  @db.Numeric(12, 2)
  
  // Crédito
  installments    Int      @default(1)
  
  createdAt       DateTime @default(now())

  @@index([saleId])
  @@index([method])
}

enum PaymentMethod {
  CASH
  CREDIT_CARD
  DEBIT_CARD
  PIX
  BOLETO
  CREDIT_ACCOUNT
  CHECK
  MIXED
}

// ============= PDV - PONTO DE VENDA =============

model PdvSession {
  id              String   @id @default(cuid())
  
  // Operador
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  
  // Valores
  openingValue    Decimal  @db.Numeric(12, 2) @default(0)
  expectedValue   Decimal  @db.Numeric(12, 2) @default(0)
  actualValue     Decimal  @db.Numeric(12, 2) @default(0)
  
  // Operações
  withdrawals     Decimal  @db.Numeric(12, 2) @default(0)
  supplies        Decimal  @db.Numeric(12, 2) @default(0)
  
  // Status
  status          PdvSessionStatus @default(OPEN)
  
  // Vendas
  sales           Sale[]
  
  // Observações
  notes           String?
  
  openedAt        DateTime @default(now())
  closedAt        DateTime?

  @@index([userId])
  @@index([status])
  @@index([openedAt])
}

enum PdvSessionStatus {
  OPEN
  CLOSED
  SUSPENDED
}

// ============= ALERTAS =============

model Alert {
  id              String   @id @default(cuid())
  
  type            AlertType
  priority        AlertPriority
  
  // Dados relacionados
  productId       String?
  supplierId      String?
  
  title           String
  message         String
  
  // Status
  read            Boolean  @default(false)
  acknowledged    Boolean  @default(false)
  
  // Configuração
  triggerDate     DateTime @default(now())
  dismissedAt     DateTime?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([type])
  @@index([priority])
  @@index([read])
  @@index([createdAt])
}

enum AlertType {
  LOW_STOCK
  CRITICAL_STOCK
  NO_MOVEMENT
  EXPIRING_SOON
  EXPIRED
  OVERDUE_PAYABLE
  UPCOMING_PAYABLE
  OVERDUE_RECEIVABLE
  HIGH_DISCOUNT
}

enum AlertPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// ============= BUSCA GLOBAL =============

model SearchHistory {
  id              String   @id @default(cuid())
  query           String
  results         Int
  createdAt       DateTime @default(now())

  @@index([query])
  @@index([createdAt])
}
